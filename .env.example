# Copy to .env and fill in. Referenced by config.yaml via ${VAR} and by compose.

# Upstream LLM providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: require this Bearer token on /v1/* (leave blank to disable auth)
PROXY_API_KEY=

# Optional: require this Bearer token on /admin/* (leave blank to disable auth)
ADMIN_API_KEY=

# Optional: point the `local` backend at your own OpenAI-compatible server
# LOCAL_LLM_URL=http://host.docker.internal:11434/v1
# LOCAL_LLM_KEY=not-needed

LOG_LEVEL=INFO
